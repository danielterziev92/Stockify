# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Java
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Binary
*.jar binary
*.war binary
*.ear binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary